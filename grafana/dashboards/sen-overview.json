      "targets": [{"datasource": {"type": "postgres", "uid": "timescaledb"}, "format": "table", "rawSql": "WITH latest AS (SELECT * FROM sen_readings ORDER BY collected_at DESC LIMIT 1) SELECT metric, value * 1000000 AS value FROM latest CROSS JOIN LATERAL (VALUES ('DOBR', dobr), ('DJER', djer), ('VARN', varn), ('KOZL1', kozl1), ('KOZL2', kozl2), ('PANCEVO21', pancevo21), ('UNGE', unge), ('MUKA', muka), ('BEKE1', beke1), ('SAND', sand), ('CHEF', chef), ('CHEA', chea), ('VULC', vulc)) AS x(metric, value) ORDER BY metric", "refId": "A"}],
